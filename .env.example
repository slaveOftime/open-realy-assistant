# Copy to .env or export these variables before running.
ASSISTANT_NAME=Gogo
ASSISTANT_SESSION_TITLE=Gogo
ASSISTANT_SESSION_TAG=gogo

# Command launched inside the managed assistant session.
ASSISTANT_COMMAND=copilot
ASSISTANT_ARGS=

